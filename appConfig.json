{
  "schemaVersion": 1,
  "defaultLocale": "es",
  "catalogUpdatedAt": "2026-03-31",
  "engines": {
    "distance_time_steps": {
      "description": "Banderazo + incrementos por distancia o tiempo de espera",
      "formula": "total = start_fee + max(distance_steps, wait_steps) * step_price + surcharges"
    },
    "meter_units": {
      "description": "Cobro por unidades de taxímetro + recargos",
      "formula": "total = max(min_fare, units * unit_price) + surcharges"
    },
    "minimum_plus_metered": {
      "description": "Se cobra mínimo hasta cierto número de unidades; luego continúa por taxímetro",
      "formula": "total = max(min_fare, units * unit_price) + surcharges"
    },
    "meter_plus_fixed_airport": {
      "description": "Taxímetro normal + recargo fijo especial",
      "formula": "total = metered_total + fixed_surcharge"
    }
  },
